#!/bin/zsh

set -u

_wt_config_file() {
  local config_home
  config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  printf '%s\n' "${WT_CONFIG_FILE:-$config_home/wt-cli/config}"
}

_wt_load_config() {
  local config_file env_default_repo env_worktree_root has_env_default_repo has_env_worktree_root

  has_env_default_repo="${+WT_DEFAULT_REPO}"
  env_default_repo="${WT_DEFAULT_REPO-}"
  has_env_worktree_root="${+WT_WORKTREE_ROOT}"
  env_worktree_root="${WT_WORKTREE_ROOT-}"
  config_file="$(_wt_config_file)"

  if [ -f "$config_file" ]; then
    . "$config_file" || {
      echo "wt: failed to load config file: $config_file" >&2
      return 1
    }
  fi

  if [ "$has_env_default_repo" -eq 1 ]; then
    WT_DEFAULT_REPO="$env_default_repo"
  fi

  if [ "$has_env_worktree_root" -eq 1 ]; then
    WT_WORKTREE_ROOT="$env_worktree_root"
  fi

  WT_DEFAULT_REPO="${WT_DEFAULT_REPO:-}"
  WT_WORKTREE_ROOT="${WT_WORKTREE_ROOT:-$HOME/.worktrees}"
}

_wt_write_config() {
  local config_file="$1"
  local default_repo="$2"
  local worktree_root="$3"
  local config_dir tmp_file

  config_dir="${config_file:h}"
  tmp_file="$config_file.tmp.$$"

  /bin/mkdir -p "$config_dir" || return 1

  {
    printf '%s\n' '# wt-cli user config'
    printf 'WT_DEFAULT_REPO=%q\n' "$default_repo"
    printf 'WT_WORKTREE_ROOT=%q\n' "$worktree_root"
  } > "$tmp_file" || return 1

  /bin/mv "$tmp_file" "$config_file" || return 1
}

_wt_load_config || exit 1

_wt_git() {
  /usr/bin/env -u GIT_DIR -u GIT_WORK_TREE /usr/bin/git "$@"
}

_wt_current_repo_root() {
  _wt_git rev-parse --show-toplevel 2>/dev/null
}

_wt_absolute_path() {
  local input="$1"
  local path="$input"

  case "$path" in
    "~")
      path="$HOME"
      ;;
    "~/"*)
      path="$HOME/${path#\~/}"
      ;;
    /*)
      ;;
    *)
      path="$PWD/$path"
      ;;
  esac

  printf '%s\n' "${path:A}"
}

_wt_pick_directory() {
  local start_dir="$1"

  if [ "$(uname -s)" != "Darwin" ]; then
    echo "wt: ':pick' is only available on macOS" >&2
    return 1
  fi

  /usr/bin/osascript - "$start_dir" <<'EOF'
on run argv
  set startDir to item 1 of argv
  set chosenFolder to choose folder with prompt "Select folder" default location (POSIX file startDir)
  POSIX path of chosenFolder
end run
EOF
}

_wt_resolve_setup_path() {
  local input="$1"
  local mode="$2"
  local current_value="$3"
  local resolved=""

  case "$input" in
    "")
      resolved="$current_value"
      ;;
    "-")
      if [ "$mode" = "repo" ]; then
        resolved=""
      else
        echo "wt: '-' is only supported for default repo" >&2
        return 1
      fi
      ;;
    ".")
      if [ "$mode" = "repo" ]; then
        resolved="$(_wt_current_repo_root)"
        if [ -z "$resolved" ]; then
          echo "wt: '.' for default repo requires running setup inside a git repository" >&2
          return 1
        fi
      else
        resolved="${PWD:A}"
      fi
      ;;
    ":pick")
      resolved="$(_wt_pick_directory "${current_value:-$PWD}")" || return 1
      resolved="${resolved%/}"
      ;;
    *)
      resolved="$(_wt_absolute_path "$input")"
      ;;
  esac

  printf '%s\n' "$resolved"
}

_wt_fzf() {
  local fzf_bin

  export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

  fzf_bin="$(command -v fzf 2>/dev/null)"
  if [ -z "$fzf_bin" ] && command -v brew >/dev/null 2>&1; then
    fzf_bin="$(brew --prefix fzf 2>/dev/null)/bin/fzf"
  fi

  if [ -z "$fzf_bin" ] || [ ! -x "$fzf_bin" ]; then
    echo "wt: fzf is required. Install it with: brew install fzf" >&2
    return 1
  fi

  printf '%s\n' "$fzf_bin"
}

_wt_require_repo() {
  local git_error

  git_error="$(_wt_git rev-parse --show-toplevel 2>&1 >/dev/null)"
  if [ $? -eq 0 ]; then
    return 0
  fi

  if [ -n "$WT_DEFAULT_REPO" ] && { [ -d "$WT_DEFAULT_REPO/.git" ] || _wt_git -C "$WT_DEFAULT_REPO" rev-parse --show-toplevel >/dev/null 2>&1; }; then
    echo "wt: not inside a git repository, defaulting to: $WT_DEFAULT_REPO" >&2
    builtin cd "$WT_DEFAULT_REPO" || return 1
    return 0
  fi

  echo "wt: not inside a git repository: $PWD" >&2
  [ -n "$git_error" ] && echo "$git_error" >&2
  if [ -n "$WT_DEFAULT_REPO" ]; then
    echo "wt: default repo not available: $WT_DEFAULT_REPO" >&2
  else
    echo "wt: set WT_DEFAULT_REPO to use wt outside a git repository" >&2
  fi
  return 1
}

_wt_help() {
  printf '%s\n' \
    'wt - Git worktree helper' \
    '' \
    'Uso:' \
    '  wt                         Lista worktrees y navega al seleccionado' \
    '  wt <rama>                  Crea/entra al worktree de esa rama' \
    '  wt --current <rama>        Crea rama nueva desde la rama actual (HEAD)' \
    '  wt delete                  Borra worktrees con multiselección' \
    '  wt setup                   Configura wt-cli para este usuario' \
    '  wt config show             Muestra la configuración efectiva' \
    '  wt config path             Muestra la ruta del archivo de config' \
    '  wt delete --force          Borra incluso con cambios locales' \
    '  wt --help                  Muestra esta ayuda' \
    '' \
    'Comportamiento de wt <rama>:' \
    '  - Si la rama ya tiene worktree: hace cd a ese worktree' \
    '  - Si la rama existe pero no tiene worktree: crea worktree y entra' \
    '  - Si la rama no existe: crea rama desde origin/develop (fetch) sin trackear develop' \
    '  - wt --current <rama> crea desde la rama actual en lugar de develop' \
    '  - Los worktrees nuevos van a WT_WORKTREE_ROOT/<repo>/<rama>' \
    '' \
    'Delete:' \
    '  - Solo lista worktrees dentro de WT_WORKTREE_ROOT/' \
    '  - Nunca lista el repo principal fuera de WT_WORKTREE_ROOT/' \
    '  - SPACE marca/desmarca, ENTER confirma selección' \
    '' \
    'Aliases:' \
    '  wt rm | del | remove       Igual que wt delete' \
    '' \
    'Nota:' \
    '  - wt-cli imprime rutas; para que haga cd usa el wrapper shell/wt.zsh.' \
    '  - Usa `wt setup` para guardar configuración persistente por usuario.' \
    '  - WT_DEFAULT_REPO y WT_WORKTREE_ROOT siguen funcionando como override.'
}

_wt_setup() {
  local config_file current_default_repo current_worktree_root default_repo worktree_root

  config_file="$(_wt_config_file)"
  current_default_repo="$WT_DEFAULT_REPO"
  current_worktree_root="$WT_WORKTREE_ROOT"

  printf '%s\n' "wt setup"
  printf '%s\n' ''
  printf '%s\n' "Config"
  printf '%s\n' "  File: $config_file"
  printf '%s\n' "  Default repo: ${current_default_repo:-<none>}"
  printf '%s\n' "  Worktree root: $current_worktree_root"
  printf '%s\n' ''
  printf '%s\n' "Input shortcuts"
  printf '%s\n' "  ENTER   Keep current config value"
  printf '%s\n' "  .       Use current repo/folder"
  printf '%s\n' "  -       Clear default repo"
  printf '%s\n' "  :pick   Open macOS folder picker"
  printf '%s\n' "  ~/...   Expand home-relative path"
  printf '%s\n' "  foo/bar Expand relative path from current directory"
  printf '%s\n' ''

  read -r "default_repo?Default repo path ('-' clears): "
  default_repo="$(_wt_resolve_setup_path "$default_repo" repo "$current_default_repo")" || return 1

  if [ -n "$default_repo" ] && ! { [ -d "$default_repo/.git" ] || _wt_git -C "$default_repo" rev-parse --show-toplevel >/dev/null 2>&1; }; then
    echo "wt: default repo is not a git repository: $default_repo" >&2
    return 1
  fi

  read -r "worktree_root?Worktree root: "
  worktree_root="$(_wt_resolve_setup_path "$worktree_root" dir "$current_worktree_root")" || return 1

  if [ -z "$worktree_root" ]; then
    echo "wt: worktree root cannot be empty" >&2
    return 1
  fi

  _wt_write_config "$config_file" "$default_repo" "$worktree_root" || {
    echo "wt: failed to write config file: $config_file" >&2
    return 1
  }

  WT_DEFAULT_REPO="$default_repo"
  WT_WORKTREE_ROOT="$worktree_root"

  echo "wt: saved config to $config_file" >&2
}

_wt_config() {
  local config_file

  config_file="$(_wt_config_file)"

  case "${1:-show}" in
    show)
      printf '%s\n' "config_file=$config_file"
      printf '%s\n' "default_repo=${WT_DEFAULT_REPO:-<none>}"
      printf '%s\n' "worktree_root=$WT_WORKTREE_ROOT"
      ;;
    path)
      printf '%s\n' "$config_file"
      ;;
    *)
      echo "wt: unknown config command: $1" >&2
      echo "wt: use 'wt config show' or 'wt config path'" >&2
      return 1
      ;;
  esac
}

_wt_select() {
  local fzf_bin selected path

  _wt_require_repo || return 1
  fzf_bin="$(_wt_fzf)" || return 1

  selected=$(
    _wt_git worktree list --porcelain |
      /usr/bin/awk '
        function flush() {
          if (path != "") {
            if (branch == "") branch = "(detached)"
            print branch "\t" path
          }
          path = ""; branch = ""
        }

        /^worktree / {
          path = substr($0, 10)
        }

        /^branch / {
          branch = substr($0, 8)
          sub(/^refs\/heads\//, "", branch)
        }

        /^detached / {
          branch = "(detached) " substr($0, 10)
        }

        /^$/ { flush() }
        END { flush() }
      ' |
      "$fzf_bin" --delimiter='\t' --with-nth=1 --prompt='worktree > '
  )

  [ -z "$selected" ] && return 1

  path=$(printf '%s\n' "$selected" | /usr/bin/cut -f2-)
  printf '%s\n' "$path"
}

_wt_resolve_base_ref() {
  local base_branch="$1"
  local remote_ref="refs/remotes/origin/$base_branch"

  _wt_git fetch origin "$base_branch" >&2 || return 1

  if _wt_git show-ref --verify --quiet "$remote_ref"; then
    printf '%s\n' "origin/$base_branch"
    return
  fi

  if _wt_git show-ref --verify --quiet "refs/heads/$base_branch"; then
    printf '%s\n' "$base_branch"
    return
  fi

  echo "wt: base branch not found: $base_branch" >&2
  return 1
}

_wt_create_or_enter() {
  local branch input_branch base_ref remote_ref remote_short existing_worktree main_worktree repo_name base safe target i use_current current_branch

  _wt_require_repo || return 1

  use_current=0
  input_branch=""

  while [ $# -gt 0 ]; do
    case "$1" in
      -c|--current)
        use_current=1
        shift
        ;;
      *)
        if [ -n "$input_branch" ]; then
          echo "wt: unexpected argument: $1" >&2
          return 1
        fi
        input_branch="$1"
        shift
        ;;
    esac
  done

  if [ -z "$input_branch" ]; then
    read -r "input_branch?Nueva rama: "
  fi

  if [ -z "$input_branch" ]; then
    echo "wt: cancelled" >&2
    return 1
  fi

  branch="$input_branch"
  case "$branch" in
    refs/heads/*)
      branch="${branch#refs/heads/}"
      ;;
    refs/remotes/origin/*)
      branch="${branch#refs/remotes/origin/}"
      ;;
    remotes/origin/*)
      branch="${branch#remotes/origin/}"
      ;;
    origin/*)
      branch="${branch#origin/}"
      ;;
  esac

  if ! _wt_git check-ref-format --branch "$branch" >/dev/null 2>&1; then
    echo "wt: invalid branch name: $input_branch" >&2
    return 1
  fi

  remote_ref="refs/remotes/origin/$branch"
  remote_short="origin/$branch"

  if ! _wt_git show-ref --verify --quiet "$remote_ref"; then
    _wt_git fetch origin "$branch" >/dev/null 2>&1 || true
  fi

  case "$input_branch" in
    refs/remotes/*|remotes/*|origin/*)
      if ! _wt_git show-ref --verify --quiet "$remote_ref"; then
        echo "wt: remote branch not found: $remote_short" >&2
        return 1
      fi
      ;;
  esac

  existing_worktree="$(_wt_git worktree list --porcelain | /usr/bin/awk -v wanted="refs/heads/$branch" '
    /^worktree / { path = substr($0, 10) }
    /^branch / && substr($0, 8) == wanted { print path; exit }
  ')"
  if [ -n "$existing_worktree" ]; then
    echo "wt: branch already has a worktree, entering it: $branch" >&2
    printf '%s\n' "$existing_worktree"
    return
  fi

  main_worktree="$(_wt_git worktree list --porcelain | /usr/bin/awk '/^worktree / { print substr($0, 10); exit }')"
  repo_name="${main_worktree:t}"
  base="$WT_WORKTREE_ROOT/$repo_name"

  safe="${branch//\//-}"
  safe="${safe// /-}"
  target="$base/$safe"
  i=2
  while [ -e "$target" ]; do
    target="$base/$safe-$i"
    i=$((i + 1))
  done

  /bin/mkdir -p "$base" || return 1

  if _wt_git show-ref --verify --quiet "refs/heads/$branch"; then
    _wt_git worktree add "$target" "$branch" >&2 || return 1
  elif _wt_git show-ref --verify --quiet "$remote_ref"; then
    _wt_git worktree add -b "$branch" "$target" "$remote_ref" >&2 || return 1
    _wt_git -C "$target" rev-parse --abbrev-ref --symbolic-full-name "@{u}" >/dev/null 2>&1 ||
      _wt_git -C "$target" branch --set-upstream-to="$remote_short" "$branch" >&2 ||
      return 1
  else
    if [ "$use_current" -eq 1 ]; then
      current_branch="$(_wt_git rev-parse --abbrev-ref HEAD 2>/dev/null)"
      echo "wt: creating branch from current HEAD ($current_branch)" >&2
      _wt_git worktree add -b "$branch" "$target" >&2 || return 1
    else
      base_ref="$(_wt_resolve_base_ref develop)" || return 1
      echo "wt: creating branch from $base_ref" >&2
      _wt_git worktree add --no-track -b "$branch" "$target" "$base_ref" >&2 || return 1
    fi
  fi

  printf '%s\n' "$target"
}

_wt_delete() {
  local fzf_bin force current_worktree main_worktree worktree_root_prefix selected count answer label path failed

  _wt_require_repo || return 1

  force="$1"
  fzf_bin="$(_wt_fzf)" || return 1
  current_worktree="$(_wt_git rev-parse --show-toplevel)"
  main_worktree="$(_wt_git worktree list --porcelain | /usr/bin/awk '/^worktree / { print substr($0, 10); exit }')"
  worktree_root_prefix="${WT_WORKTREE_ROOT%/}/"

  selected=$(
    _wt_git worktree list --porcelain |
      /usr/bin/awk -v main="$main_worktree" -v current="$current_worktree" -v worktree_root_prefix="$worktree_root_prefix" '
        function flush() {
          if (path != "" && index(path, worktree_root_prefix) == 1 && path != main && path != current) {
            if (branch == "") branch = "(detached)"
            print branch "\t" path
          }
          path = ""; branch = ""
        }

        /^worktree / {
          path = substr($0, 10)
        }

        /^branch / {
          branch = substr($0, 8)
          sub(/^refs\/heads\//, "", branch)
        }

        /^detached / {
          branch = "(detached) " substr($0, 10)
        }

        /^$/ { flush() }
        END { flush() }
      ' |
      while IFS=$'\t' read -r label path; do
        if [ -n "$(_wt_git -C "$path" status --short 2>/dev/null)" ]; then
          label="$label  [dirty]"
        fi
        printf '%s\t%s\n' "$label" "$path"
      done |
      "$fzf_bin" \
        --multi \
        --bind='space:toggle' \
        --delimiter='\t' \
        --with-nth=1 \
        --prompt='delete worktree > ' \
        --header="SPACE marca, ENTER confirma selección; solo se listan worktrees de $WT_WORKTREE_ROOT"
  )

  [ -z "$selected" ] && return

  count=$(printf '%s\n' "$selected" | /usr/bin/wc -l | /usr/bin/tr -d ' ')
  echo "Vas a borrar $count worktree(s):" >&2
  printf '%s\n' "$selected" | /usr/bin/cut -f1 | /usr/bin/sed 's/^/  - /' >&2

  if [ "$force" = "force" ]; then
    echo "Modo force activado: se borrarán incluso con cambios locales." >&2
  else
    echo "Si alguno tiene cambios locales, Git lo rechazará. Usa: wt delete --force" >&2
  fi

  read -r "answer?Confirmar borrado? [y/N] "
  case "$answer" in
    y|Y|yes|YES|s|S|si|sí|SI|SÍ) ;;
    *) echo "wt: cancelled" >&2; return 1 ;;
  esac

  failed=0
  while IFS=$'\t' read -r label path; do
    [ -z "$path" ] && continue
    if [ "$force" = "force" ]; then
      _wt_git worktree remove --force "$path" || failed=1
    else
      _wt_git worktree remove "$path" || failed=1
    fi
  done <<EOF
$selected
EOF

  [ "$failed" -eq 0 ] && echo "wt: deleted selected worktrees" >&2
  return "$failed"
}

case "${1:-}" in
  -h|--help|help)
    _wt_help
    ;;
  setup)
    shift
    _wt_setup "$@"
    ;;
  config)
    shift
    _wt_config "$@"
    ;;
  delete|del|remove|rm)
    case "${2:-}" in
      -f|--force|force)
        _wt_delete force
        ;;
      *)
        _wt_delete ""
        ;;
    esac
    ;;
  "")
    _wt_select
    ;;
  *)
    _wt_create_or_enter "$@"
    ;;
esac
